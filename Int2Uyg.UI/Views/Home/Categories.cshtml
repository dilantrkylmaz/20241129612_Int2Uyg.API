@{
    ViewData["Title"] = "Anket Kategorileri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Anket Kategorileri Yönetimi</h1>
    <button class="d-none d-sm-inline-block btn btn-primary shadow-sm" id="btnEkle">
        <i class="fas fa-plus text-white-50"></i> Yeni Kategori Ekle
    </button>
</div>

<div class="row" id="categoryCards">
    <div class="col-12 text-center mt-5" id="loader">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 font-weight-bold text-gray-600">Sistem Hazırlanıyor...</p>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            var ApiBaseUrl = "@ViewBag.ApiBaseUrl";

            function KategoriListele() {
                $.ajax({
                    url: ApiBaseUrl + "api/Category",
                    method: "GET",
                    success: function (data) {
                        $("#loader").hide();
                        KartlariOlustur(data);
                    },
                    error: function (err) {
                        $("#loader").hide();
                        $("#categoryCards").html('<div class="col-12"><div class="alert alert-danger shadow-sm">Bağlantı hatası! Lütfen API projenizi kontrol edin.</div></div>');
                    }
                });
            }

            function KartlariOlustur(data) {
                $("#categoryCards").empty();
                var html = "";

                var gorulenKategoriler = [];

                $.each(data, function (index, item) {

                    var kategoriAdi = item.name.trim().toLowerCase();
                    if (gorulenKategoriler.includes(kategoriAdi)) {
                        return true; 
                    }
                    gorulenKategoriler.push(kategoriAdi); 

                    var durumBadge = item.isActive
                        ? '<span class="badge badge-success px-2 py-1">Aktif</span>'
                        : '<span class="badge badge-danger px-2 py-1">Pasif</span>';

                    var toggleColor = item.isActive ? "btn-success" : "btn-secondary";
                    var toggleIcon = item.isActive ? "fa-toggle-on" : "fa-toggle-off";
                    var toggleTitle = item.isActive ? "Pasif Yap" : "Aktif Yap";

                    html += `
                        <div class="col-xl-4 col-md-6 mb-4">
                            <div class="card border-left-primary shadow h-100 py-2">
                                <div class="card-body">
                                    <div class="row no-gutters align-items-center">
                                        <div class="col mr-2">
                                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1 durum-alani">
                                                Durum: ${durumBadge}
                                            </div>
                                            <div class="h5 mb-0 font-weight-bold text-gray-800">${item.name}</div>
                                            <p class="mt-2 text-sm text-gray-600">${item.description}</p>
                                        </div>
                                        <div class="col-auto">
                                            <i class="fas fa-folder-open fa-2x text-gray-300"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-white border-0 text-center pt-0">
                                    <hr class="mt-0 mb-2">

                                    <a href="/Surveys/${item.id}" class="btn btn-info px-3" title="Anketleri Göster">
                                        <i class="fas fa-list"></i> Anketler
                                    </a>

                                    <button class="btn ${toggleColor} px-3 btn-durum" data-id="${item.id}" data-isactive="${item.isActive}" title="${toggleTitle}">
                                        <i class="fas ${toggleIcon} fa-lg"></i>
                                    </button>

                                    <button class="btn btn-warning px-3 btn-duzenle" data-id="${item.id}" title="Düzenle">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <button class="btn btn-danger px-3 btn-sil" data-id="${item.id}" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                });

                $("#categoryCards").html(html);
            }

            KategoriListele();

            $(document).on("click", ".btn-durum", function () {
                var buton = $(this);
                var kart = buton.closest(".card");

                var mevcutDurum = buton.data("isactive");
                var yeniDurum = (mevcutDurum === true || mevcutDurum === "true") ? false : true;

                buton.data("isactive", yeniDurum);

                if (yeniDurum === true) {
                    buton.removeClass("btn-secondary").addClass("btn-success");
                    buton.find("i").removeClass("fa-toggle-off").addClass("fa-toggle-on");
                    buton.attr("title", "Pasif Yap");
                    kart.find(".durum-alani").html('Durum: <span class="badge badge-success px-2 py-1">Aktif</span>');
                } else {
                    buton.removeClass("btn-success").addClass("btn-secondary");
                    buton.find("i").removeClass("fa-toggle-on").addClass("fa-toggle-off");
                    buton.attr("title", "Aktif Yap");
                    kart.find(".durum-alani").html('Durum: <span class="badge badge-danger px-2 py-1">Pasif</span>');
                }
            });

        });
    </script>
}