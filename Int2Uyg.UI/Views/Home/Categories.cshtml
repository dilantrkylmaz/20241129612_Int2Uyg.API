@{
	ViewData["Title"] = "Anket Kategorileri";
}

<div class="row">
	<div class="col-md-8" id="listArea">
		<div class="card shadow mb-4">
			<div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-primary text-white">
				<h6 class="m-0 font-weight-bold"><i class="fas fa-list mr-2"></i>Anket Kategorileri</h6>
			</div>
			<div class="card-body">
				<div class="table-responsive">
					<table class="table table-bordered table-hover" id="tbCategoryList" width="100%" cellspacing="0">
						<thead>
							<tr class="bg-light text-dark">
								<th>Kategori Adı</th>
								<th>Anket Sayısı</th>
								<th>Durumu</th>
								<th id="thActions" style="width: 100px;">İşlemler</th>
							</tr>
						</thead>
						<tbody>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<div class="col-md-4" id="formArea">
		<div class="card shadow mb-4 border-left-primary">
			<div class="card-header py-3 bg-white text-primary">
				<h6 class="m-0 font-weight-bold" id="formTitle">Yeni Kategori Ekle</h6>
			</div>
			<div class="card-body">
				<form id="frmCategory">
					<input type="hidden" id="txtId" />
					<div class="form-group">
						<label class="font-weight-bold text-dark small">Kategori Adı</label>
						<input type="text" class="form-control" id="txtName" placeholder="Örn: Yazılım Eğitimleri">
					</div>
					<div class="form-group">
						<div class="custom-control custom-checkbox small">
							<input type="checkbox" class="custom-control-input" id="cbIsActive" checked>
							<label class="custom-control-label" for="cbIsActive">Kategori Aktif mi?</label>
						</div>
					</div>

					<div class="mt-4">
						<button type="button" class="btn btn-primary btn-block shadow-sm font-weight-bold" id="btnSave">
							<i class="fa fa-save mr-1"></i> Kaydet
						</button>
						<div id="editButtons" style="display:none;">
							<button type="button" class="btn btn-warning btn-block shadow-sm font-weight-bold" id="btnUpdate">
								<i class="fa fa-edit mr-1"></i> Güncelle
							</button>
							<button type="button" class="btn btn-danger btn-block shadow-sm font-weight-bold" id="btnDelete">
								<i class="fa fa-trash mr-1"></i> Sil
							</button>
							<button type="button" class="btn btn-secondary btn-block shadow-sm" id="btnCancel">
								<i class="fa fa-times mr-1"></i> Vazgeç
							</button>
						</div>
					</div>
				</form>
				<div id="divResult" class="mt-3" style="display:none;"></div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		$(document).ready(function () {
			var apiBaseUrl = "@ViewBag.ApiBaseURL";
			var token = localStorage.getItem("token");

			if (!token) { window.location.href = "/Login"; return; }

			var payload = parseJwt(token);
			var roles = payload ? payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] : null;
			var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));


			if (!isAdmin) {
				$("#formArea").remove();
				$("#listArea").removeClass("col-md-8").addClass("col-md-12");
				$("#thActions").hide(); 
			}

			GetCategoryList();


			function GetCategoryList() {
				$.ajax({
					url: apiBaseUrl + "/Category/List",
					type: "GET",
					headers: { "Authorization": "Bearer " + token },
					success: function (data) {
						var row = "";
						$("#tbCategoryList tbody").empty();

						$.each(data, function (i, item) {
							var statusBadge = item.isActive ?
								'<span class="badge badge-success">Aktif</span>' :
								'<span class="badge badge-danger">Pasif</span>';

							row += "<tr>";
							row += "<td class='text-dark'>" + toTitleCase(item.name) + "</td>";
							row += "<td>" + (item.surveyCount || 0) + " Anket</td>";
							row += "<td>" + statusBadge + "</td>";


							if (isAdmin) {
								row += '<td><button class="btn btn-info btn-sm btnEdit" data-id="' + item.id + '"><i class="fa fa-edit"></i> Seç</button></td>';
							}
							row += "</tr>";
						});
						$("#tbCategoryList tbody").append(row);
					}
				});
			}



			$("#btnSave").click(function () {
				var name = $("#txtName").val();
				if (!name) { showResult("Lütfen kategori adı giriniz!", "danger"); return; }

				var category = { name: name, isActive: $("#cbIsActive").is(":checked") };

				$.ajax({
					url: apiBaseUrl + "/Category/Add",
					type: "POST",
					contentType: "application/json",
					headers: { "Authorization": "Bearer " + token },
					data: JSON.stringify(category),
					success: function (d) {
						if (d.status) {
							showResult(d.message || "Kategori eklendi!", "success");
							ResetForm();
							GetCategoryList();
						} else {
							showResult(d.message, "danger");
						}
					}
				});
			});



			$(document).on("click", ".btnEdit", function () {
				var id = $(this).data("id");
				$.ajax({
					url: apiBaseUrl + "/Category/GetById/" + id,
					type: "GET",
					headers: { "Authorization": "Bearer " + token },
					success: function (d) {
						$("#txtId").val(d.id || d.Id);
						$("#txtName").val(d.name || d.Name);
						var activeState = d.isActive !== undefined ? d.isActive : d.IsActive;
						$("#cbIsActive").prop("checked", activeState);

						$("#btnSave").hide();
						$("#editButtons").show();
						$("#formTitle").text("Kategoriyi Düzenle");
					}
				});
			});



			$("#btnUpdate").click(function () {
				var rawId = $("#txtId").val();
				var name = $("#txtName").val();

				if (!rawId) { showResult("Önce bir kategori seçin!", "danger"); return; }

				var category = {
					id: parseInt(rawId),
					name: name,
					description: " ",
					isActive: $("#cbIsActive").is(":checked")
				};

				$.ajax({
					url: apiBaseUrl + "/Category/Update",
					type: "PUT",
					contentType: "application/json",
					headers: { "Authorization": "Bearer " + token },
					data: JSON.stringify(category),
					success: function (d) {
						if (d.status) {
							showResult(d.message || "Güncellendi!", "success");
							ResetForm();
							GetCategoryList();
						} else {
							showResult(d.message, "danger");
						}
					}
				});
			});



			$("#btnDelete").click(function () {
				var id = parseInt($("#txtId").val());
				if (!id) { showResult("Önce bir kategori seçin!", "danger"); return; }

				if(confirm("Silmek istediğinize emin misiniz?")) {
					$.ajax({
						url: apiBaseUrl + "/Category/Delete/" + id,
						type: "DELETE",
						headers: { "Authorization": "Bearer " + token },
						success: function (d) {
							if (d.status) {
								showResult(d.message || "Silindi!", "success");
								ResetForm();
								GetCategoryList();
							} else {
								showResult(d.message, "danger");
							}
						}
					});
				}
			});


			function ResetForm() {
				$("#frmCategory")[0].reset();
				$("#txtId").val("");
				$("#btnSave").show();
				$("#editButtons").hide();
				$("#formTitle").text("Yeni Kategori Ekle");
			}

			$("#btnCancel").click(function () { ResetForm(); });

			function showResult(message, type) {
				$("#divResult").stop(true, true).hide()
					.removeClass().addClass("alert alert-" + type)
					.html(message).fadeIn(500);

				setTimeout(function() {
					$("#divResult").fadeOut(1000);
				}, 4000);
			}

			function toTitleCase(str) {
				if(!str) return "";
				return str.split(' ').map(function(word) {
					return word.charAt(0).toLocaleUpperCase('tr-TR') + word.slice(1).toLocaleLowerCase('tr-TR');
				}).join(' ');
			}
		});
	</script>
}