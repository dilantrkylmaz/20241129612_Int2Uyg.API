@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Anket Portalı | Şifremi Unuttum</title>

    <link href="~/sbadmin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="~/sbadmin/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body class="bg-gradient-primary">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12 col-md-9">
                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <div class="row">
                            <div class="col-lg-6 d-none d-lg-block" style="background: url('https://images.unsplash.com/photo-1614064641913-6b20a40e81f5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80') center center; background-size: cover;"></div>

                            <div class="col-lg-6">
                                <div class="p-5">
                                    <div class="text-center">
                                        <h1 class="h4 text-gray-900 mb-2 font-weight-bold">Şifrenizi mi Unuttunuz?</h1>
                                        <p class="mb-4 text-muted">Hiç sorun değil! E-posta adresinizi aşağıya girin, size şifrenizi sıfırlamanız için bir bağlantı gönderelim.</p>
                                    </div>

                                    <form class="user" id="frmForgot">
                                        <div class="form-group">
                                            <input type="email" class="form-control form-control-user"
                                                   id="txtEmail" aria-describedby="emailHelp"
                                                   placeholder="E-Posta Adresinizi Girin...">
                                        </div>
                                        <button type="button" id="btnReset" class="btn btn-primary btn-user btn-block font-weight-bold">
                                            <i class="fas fa-envelope mr-1"></i> Şifre Sıfırlama Bağlantısı Gönder
                                        </button>
                                    </form>

                                    <hr>

                                    <div id="divResult" class="mt-3" style="display:none;"></div>

                                    <div class="text-center mt-4">
                                        <a class="small font-weight-bold" href="/Register" style="color: #4e73df;">
                                            <i class="fas fa-user-plus"></i> Yeni Hesap Oluştur!
                                        </a>
                                    </div>
                                    <div class="text-center mt-2">
                                        <a class="small font-weight-bold" href="/Login" style="color: #e74a3b;">
                                            <i class="fas fa-sign-in-alt"></i> Zaten hesabınız var mı? Giriş Yapın
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/sbadmin/vendor/jquery/jquery.min.js"></script>
    <script src="~/sbadmin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#btnReset").click(function () {
                var email = $("#txtEmail").val();
                var btn = $(this);

                if (!email) {
                    showResult("Lütfen e-posta adresinizi girin!", "danger");
                    return;
                }

                var originalText = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin mr-1"></i> Veritabanı Kontrol Ediliyor...').prop("disabled", true);

                setTimeout(function() {
                    btn.html(originalText).prop("disabled", false);

                    showResult("Şifre sıfırlama bağlantısı e-posta adresinize başarıyla gönderildi.", "success");

                    setTimeout(function() {
                        window.location.href = "/Login";
                    }, 3000);

                }, 2000); 
            });

            function showResult(message, type) {
                $("#divResult")
                    .fadeIn()
                    .removeClass()
                    .addClass("alert alert-" + type + " text-center")
                    .html(message);
            }
        });
    </script>
</body>
</html>