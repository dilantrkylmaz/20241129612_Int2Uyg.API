@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Anket Portalı - Kayıt Ol</title>

    <link href="~/sbadmin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="~/sbadmin/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body class="bg-gradient-primary">
    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-register-image" style="background-image: url('https://source.unsplash.com/Mv9hjnEUHR4/600x800'); background-size: cover;"></div>
                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4 font-weight-bold">Yeni Hesap Oluştur!</h1>
                                <p class="mb-4">Anketlere katılmak ve dünyayı şekillendirmek için hemen üye ol.</p>
                            </div>
                            <form class="user" id="frmRegister">
                                <div class="form-group row">
                                    <div class="col-sm-12 mb-3 mb-sm-0">
                                        <input type="text" class="form-control form-control-user" id="txtFullName" placeholder="Adınız Soyadınız">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <input type="text" class="form-control form-control-user" id="txtUserName" placeholder="Kullanıcı Adı">
                                </div>
                                <div class="form-group">
                                    <input type="email" class="form-control form-control-user" id="txtEmail" placeholder="E-Posta Adresi">
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <input type="password" class="form-control form-control-user" id="txtPassword" placeholder="Şifre">
                                    </div>
                                    <div class="col-sm-6">
                                        <input type="password" class="form-control form-control-user" id="txtPasswordConfirm" placeholder="Şifre Tekrar">
                                    </div>
                                </div>
                                <button type="button" id="btnRegister" class="btn btn-primary btn-user btn-block font-weight-bold">
                                    Hesabı Oluştur
                                </button>
                            </form>
                            <hr>
                            <div id="divResult" class="mt-3" style="display:none;"></div>
                            <div class="text-center">
                                <a class="small font-weight-bold" href="/Login">Zaten bir hesabın var mı? Giriş Yap!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/sbadmin/vendor/jquery/jquery.min.js"></script>
    <script src="~/sbadmin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            var apiBaseUrl = "@ViewBag.ApiBaseURL";

            $("#btnRegister").click(function () {
                var fullName = $("#txtFullName").val();
                var userName = $("#txtUserName").val();
                var email = $("#txtEmail").val();
                var password = $("#txtPassword").val();
                var confirmPassword = $("#txtPasswordConfirm").val();


                if (!fullName || !userName || !email || !password) {
                    showResult("Lütfen tüm alanları doldurunuz!", "danger");
                    return;
                }

                if (password !== confirmPassword) {
                    showResult("Şifreler birbiriyle uyuşmuyor!", "danger");
                    return;
                }

                var registerData = {
                    FullName: fullName,
                    UserName: userName,
                    Email: email,
                    Password: password
                };

                $.ajax({
                    url: apiBaseUrl + "/User/Register",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(registerData),
                    success: function (response) {
                        if (response.status) {
                            showResult("Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz...", "success");
                            setTimeout(function () {
                                window.location.href = "/Login";
                            }, 2000);
                        } else {
                            showResult(response.message, "danger");
                        }
                    },
                    error: function () {
                        showResult("Bir hata oluştu. Lütfen tekrar deneyin.", "danger");
                    }
                });
            });

            function showResult(message, type) {
                $("#divResult").fadeIn().removeClass().addClass("alert alert-" + type).html(message);
            }
        });
    </script>
</body>
</html>